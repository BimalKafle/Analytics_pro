# Docker Compose overrides (all values have safe local defaults).
# Copy to .env at the repository root only if you need to change a value.
# These are local development credentials only — never use them in production.

# Host port for the Laravel app
APP_PORT=8000

# PostgreSQL (must match backend/.env database settings)
DB_DATABASE=creator_analytics
DB_USERNAME=analytics
DB_PASSWORD=secret
DB_PORT=5432

# Redis
REDIS_PORT=6379
